{
  "manifest_version": 3,
  "name": "Slide Sync",
  "version": "2.0.0",
  "description": "Compartilhe slides da aula em tempo real com seus alunos",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["http://localhost:*/*", "https://*/*"],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://docs.google.com/presentation/d/*/edit*",
        "*://docs.google.com/presentation/d/*/present*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
